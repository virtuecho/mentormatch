{
	"name": "@mentormatch/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"dependencies": {
		"@mentormatch/db": "workspace:*",
		"@mentormatch/feature-admin": "workspace:*",
		"@mentormatch/feature-auth": "workspace:*",
		"@mentormatch/feature-availability": "workspace:*",
		"@mentormatch/feature-bookings": "workspace:*",
		"@mentormatch/feature-mentors": "workspace:*",
		"@mentormatch/feature-profile": "workspace:*",
		"@mentormatch/shared": "workspace:*",
		"@mentormatch/ui": "workspace:*",
		"bcryptjs": "^3.0.3",
		"jose": "^6.2.2",
		"zod": "^4.3.6"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:e2e": "vite dev --host 127.0.0.1 --port 4173 --strictPort",
		"build": "pnpm exec vite build",
		"preview": "wrangler dev worker-entry.ts --port 4173 --inspector-port 0",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --config vitest.config.ts --run",
		"test": "pnpm run test:unit && pnpm run test:e2e",
		"test:e2e": "playwright test",
		"gen": "wrangler types",
		"cf:deploy": "wrangler deploy",
		"cf:preview": "wrangler dev worker-entry.ts --local --port 4173"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^22",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"wrangler": "^4.63.0"
	}
}
