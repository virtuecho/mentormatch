{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".svelte-kit/**"
      ]
    },
    "check": {
      "dependsOn": [
        "^check"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "format": {
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": [
        "coverage/**",
        "test-results/**"
      ]
    },
    "test:unit": {
      "dependsOn": [
        "^test:unit"
      ],
      "outputs": [
        "coverage/**"
      ]
    }
  }
}

